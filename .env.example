# ==========================================
# CONFIGURACIÓN GENERAL DEL MONITOR (NIDUS)
# ==========================================
PORT=8000
HOST=0.0.0.0

# Orígenes CORS permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# ==========================================
# BASE DE DATOS (POSTGRESQL)
# ==========================================
# Configuración del contenedor de Base de Datos
DB_USER=baby_admin
DB_PASSWORD=baby_secure_password_2026
DB_NAME=nidus_monitor
DB_HOST=db
DB_PORT=5432

# URL de conexión (usada por el servidor FastAPI)
# Si corres localmente fuera de docker, cambia 'db' por 'localhost'
DATABASE_URL=postgresql://baby_admin:baby_secure_password_2026@db:5432/nidus_monitor

# ==========================================
# SEGURIDAD Y JWT
# ==========================================
# ¡IMPORTANTE! Cambia esta clave en producción por un valor aleatorio y seguro
JWT_SECRET=super_secret_baby_key_2026_random_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# NOTIFICACIONES FIREBASE (FCM)
# ==========================================
# Ruta absoluta o relativa al contenedor para el archivo JSON de credenciales FCM
FCM_CREDENTIALS_PATH=/app/secrets/serviceAccountKey.json

# ==========================================
# OPTIMIZACIÓN IA (MediaPipe)
# ==========================================
# Cuadros por segundo a analizar (5 fps reduce drásticamente el uso de CPU)
PROCESS_FPS=5
# Dimensiones a las que se reduce el video antes del análisis
PROCESS_WIDTH=320
PROCESS_HEIGHT=240

# ==========================================
# UMBRALES DE DETECCIÓN Y ESTADOS
# ==========================================
# Relación de aspecto del ojo (EAR) por debajo de la cual se considera ojo cerrado
EAR_THRESHOLD=0.2
# Frames consecutivos (a PROCESS_FPS) con ojos abiertos para activar estado Despierto (ej. 15 frames = 3 seg)
EAR_CONSECUTIVE_FRAMES=15
